    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "lucide-react": "^0.546.0",
    "mammoth": "^1.12.0",
    "midtrans-client": "^1.4.3",
    "motion": "^12.38.0",
    "nodemailer": "^8.0.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
